{
  "compilerOptions": {
    "target": "ES2022",
    "module": "CommonJS",
    "moduleResolution": "node",
    "lib": ["ES2022"],
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "noEmit": true,
    "paths": {
      "@planningo/trading-core": ["../../packages/trading-core/src/index.ts"]
    }
  },
  "include": ["src/**/*", "../../packages/trading-core/src/**/*"],
  "exclude": ["node_modules", "dist"]
}
