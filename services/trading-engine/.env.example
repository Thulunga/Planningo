# Supabase (use SERVICE ROLE key — bypasses RLS)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJhbGci...

# The admin user's Supabase auth UUID (run SELECT id FROM profiles WHERE email = 'your@email.com')
ADMIN_USER_ID=00000000-0000-0000-0000-000000000000

# Engine version tag (optional — shown in UI)
ENGINE_VERSION=1.0.0

# Scan interval in seconds during market hours (default: 300 = 5 min)
SCAN_INTERVAL_SECONDS=300
